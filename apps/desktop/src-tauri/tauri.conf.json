{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Locke",
  "version": "0.0.0",
  "identifier": "com.locke.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Locke",
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#0a0c11"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
