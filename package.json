{
  "name": "locke",
  "version": "0.0.0",
  "private": true,
  "description": "Locke — review what your agents built locally before it reaches origin/main.",
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "dev": "pnpm --filter @locke/desktop dev",
    "tauri": "pnpm --filter @locke/desktop tauri",
    "build": "pnpm --filter @locke/desktop build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
